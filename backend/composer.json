{
  "name": "travelhub/backend",
  "description": "TravelHub Backend - Enterprise Travel Ecosystem Platform",
  "keywords": [
    "travel",
    "booking",
    "marketplace",
    "vendor",
    "laravel",
    "api"
  ],
  "license": "proprietary",
  "type": "project",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^12.0",
    "laravel/sanctum": "^4.0",
    "laravel/tinker": "^2.8",
    "doctrine/dbal": "^3.6",
    "stripe/stripe-php": "^14.0",
    "symfony/http-client": "^7.0",
    "laravel/scout": "^10.0",
    "elasticsearch/elasticsearch": "^8.0",
    "predis/predis": "^2.2",
    "intervention/image": "^3.0",
    "spatie/laravel-permissions": "^6.0",
    "spatie/laravel-audit": "^4.0",
    "spatie/laravel-medialibrary": "^11.0",
    "laravel/cashier": "^15.0",
    "laravel-notification-channels/twilio": "^3.0",
    "mailersend/mailersend": "^1.3",
    "ramsey/uuid": "^4.7",
    "barryvdh/laravel-cors": "^2.1",
    "laravel/horizon": "^5.0",
    "laravel/octane": "^2.0",
    "sentry/sentry-laravel": "^4.0",
    "lorisleiva/laravel-actions": "^2.0",
    "juststeveking/laravel-gis": "^1.8"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "laravel/pint": "^1.14",
    "laravel/sail": "^1.27",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.0",
    "nunomaduro/larastan": "^2.0",
    "pestphp/pest": "^2.28",
    "pestphp/pest-plugin-laravel": "^2.0",
    "phpstan/phpstan": "^1.10",
    "phpunit/phpunit": "^11.0",
    "spatie/laravel-ray": "^1.32"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi",
      "@php artisan storage:link"
    ],
    "pint": "pint",
    "test": "pest",
    "test:unit": "pest --group=unit",
    "test:feature": "pest --group=feature",
    "test:coverage": "pest --coverage",
    "stan": "phpstan analyse"
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
